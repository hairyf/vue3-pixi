{
  "name": "vue3-pixi-nuxt",
  "type": "module",
  "version": "1.0.1",
  "description": "Nuxt createRenderer for PixiJS",
  "license": "MIT",
  "homepage": "https://github.com/hairyf/vue3-pixi#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hairyf/vue3-pixi.git"
  },
  "bugs": {
    "url": "https://github.com/hairyf/vue3-pixi/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pixi.js",
    "vue"
  ],
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build prepare && nuxt-module-build build",
    "dev": "npm run dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "prepublishOnly": "npm run prepack",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
  },
  "dependencies": {
    "@nuxt/kit": "catalog:nuxt",
    "vue3-pixi": "workspace:^"
  },
  "devDependencies": {
    "@nuxt/devtools": "catalog:nuxt",
    "@nuxt/module-builder": "catalog:nuxt",
    "@nuxt/schema": "catalog:nuxt",
    "@nuxt/test-utils": "catalog:nuxt",
    "@types/node": "catalog:types",
    "nuxt": "catalog:nuxt",
    "typescript": "catalog:cli",
    "vitest": "catalog:cli",
    "vue-tsc": "catalog:nuxt"
  }
}
